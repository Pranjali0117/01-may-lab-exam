<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lab Exam - Courses</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        max-width: 500px;
        margin: 60px auto;
        background: #f4f4f4;
      }
      h1 {
        color: #333;
      }
      ul {
        background: white;
        padding: 20px 40px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }
      li {
        padding: 8px 0;
        font-size: 18px;
        color: #444;
        border-bottom: 1px solid #eee;
      }
      li:last-child {
        border-bottom: none;
      }
    </style>
  </head>
  <body>
    <h1>Available Courses</h1>

    <ul>
      <% courses.forEach(function(course) { %>
        <li><%= course %></li>
      <% }); %>
    </ul>
  </body>
</html>
